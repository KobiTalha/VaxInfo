generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum DiseaseSeverity {
  low
  moderate
  high_risk
  mandatory
}

enum VaccineType {
  live
  mrna
  inactive
  subunit
  toxoid
  vector
  recombinant
}

model Disease {
  id             Int            @id @default(autoincrement())
  name           String         @unique
  aliases        String[]       @default([])
  category       String         @default("unknown")
  severity       DiseaseSeverity @default(moderate)
  mandatory      Boolean        @default(false)
  vaccines       Vaccine[]
  savedByUsers   SavedDisease[]
  searchLogs     SearchLog[]
}

model Vaccine {
  id               Int         @id @default(autoincrement())
  diseaseId        Int
  name             String
  type             String
  doses            String      @default("N/A")
  coveragePercent  Float?
  region           String?
  introductionYear Int?
  sideEffects      String[]    @default([])
  dosageSchedule   String      @default("See national schedule")
  ageGroup         String      @default("General population")
  vaccineType      VaccineType @default(inactive)
  disease          Disease     @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  kind      String?
  disease   String?
  score     Float?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model SearchLog {
  id        String    @id @default(uuid())
  query     String
  region    String?
  diseaseId Int?
  userId    String?
  createdAt DateTime  @default(now())
  disease   Disease?  @relation(fields: [diseaseId], references: [id], onDelete: SetNull)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([query])
  @@index([region])
}

model User {
  id                 String                  @id @default(cuid())
  name               String?
  email              String?                 @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  role               String                  @default("user")
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  accounts           Account[]
  sessions           Session[]
  chatSessions       ChatSession[]
  savedDiseases      SavedDisease[]
  dashboardPreference UserDashboardPreference?
  apiKeys            ApiKey[]
  searchLogs         SearchLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SavedDisease {
  id        String   @id @default(cuid())
  userId    String
  diseaseId Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  disease   Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@unique([userId, diseaseId])
  @@index([userId, createdAt])
}

model UserDashboardPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  preferredRegion String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id                 String     @id @default(cuid())
  userId             String
  name               String
  keyHash            String
  prefix             String
  isActive           Boolean    @default(true)
  rateLimitPerMinute Int        @default(60)
  lastUsedAt         DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages             ApiUsage[]

  @@index([userId, createdAt])
  @@index([prefix])
}

model ApiUsage {
  id         String   @id @default(cuid())
  apiKeyId   String?
  endpoint   String
  method     String
  statusCode Int
  ipAddress  String?
  createdAt  DateTime @default(now())
  apiKey     ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([endpoint, createdAt])
}

model ErrorLog {
  id        String   @id @default(cuid())
  path      String
  method    String
  message   String
  stack     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path, createdAt])
}
